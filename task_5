import tkinter as tk
from tkinter import scrolledtext, messagebox, filedialog
import socket
import threading
import json
import xml.etree.ElementTree as ET
import os

HOST = '127.0.0.1'
PORT = 8888
DATA_DIR = 'server_files'
os.makedirs(DATA_DIR, exist_ok=True)


class FileServerApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Файловый сервер")
        self.root.geometry("700x500")
        self.server_running = False
        self.server_socket = None

        btn_frame = tk.Frame(root)
        btn_frame.pack(pady=5)

        self.btn_start = tk.Button(btn_frame, text="Запустить сервер", command=self.start_server, bg='green',
                                   fg='white')
        self.btn_start.pack(side=tk.LEFT, padx=5)

        self.btn_stop = tk.Button(btn_frame, text="Остановить сервер", command=self.stop_server, bg='red', fg='white',
                                  state=tk.DISABLED)
        self.btn_stop.pack(side=tk.LEFT, padx=5)

        btn_upload = tk.Button(btn_frame, text="Загрузить файл", command=self.upload_file, bg='blue', fg='white')
        btn_upload.pack(side=tk.LEFT, padx=5)

        btn_list = tk.Button(btn_frame, text="Список файлов", command=self.list_files, bg='purple', fg='white')
        btn_list.pack(side=tk.LEFT, padx=5)

        frame = tk.Frame(root)
        frame.pack(pady=5)
        tk.Label(frame, text="Имя файла для скачивания:").pack(side=tk.LEFT)
        self.filename_entry = tk.Entry(frame, width=20)
        self.filename_entry.pack(side=tk.LEFT, padx=5)
        btn_download = tk.Button(frame, text="Скачать", command=self.download_file, bg='orange', fg='white')
        btn_download.pack(side=tk.LEFT)

        self.log = scrolledtext.ScrolledText(root, height=25, font=("Courier", 9))
        self.log.pack(fill='both', expand=True, padx=10, pady=5)

    def log_msg(self, msg):
        self.log.insert(tk.END, f"{msg}\n")
        self.log.see(tk.END)

    def validate_json(self, data):
        try:
            json.loads(data)
            return True
        except:
            return False

    def validate_xml(self, data):
        try:
            ET.fromstring(data)
            return True
        except:
            return False

    def handle_client(self, conn, addr):
        self.log_msg(f"Клиент подключен: {addr}")
        while True:
            try:
                cmd = conn.recv(1024).decode()
                if not cmd:
                    break

                if cmd == "UPLOAD":
                    name = conn.recv(1024).decode()
                    ext = conn.recv(1024).decode()
                    size = int(conn.recv(1024).decode())
                    data = b''
                    while len(data) < size:
                        data += conn.recv(4096)

                    valid = (ext == '.json' and self.validate_json(data.decode())) or (
                                ext == '.xml' and self.validate_xml(data.decode()))
                    if valid:
                        with open(os.path.join(DATA_DIR, name + '.bin'), 'wb') as f:
                            f.write(data)
                        conn.send(b"OK")
                        self.log_msg(f"✓ {name}{ext} загружен")
                    else:
                        conn.send(b"INVALID")
                        self.log_msg(f"✗ {name}{ext} не прошел валидацию")

                elif cmd == "DOWNLOAD":
                    name = conn.recv(1024).decode()
                    path = os.path.join(DATA_DIR, name)
                    if os.path.exists(path):
                        size = os.path.getsize(path)
                        conn.send(str(size).encode())
                        conn.recv(1024)
                        with open(path, 'rb') as f:
                            conn.sendfile(f)
                        self.log_msg(f"✓ {name} отправлен")
                    else:
                        conn.send(b"-1")

                elif cmd == "LIST":
                    files = '\n'.join([f for f in os.listdir(DATA_DIR) if f.endswith('.bin')])
                    conn.send(str(len(files)).encode())
                    conn.recv(1024)
                    conn.send(files.encode())

                elif cmd == "EXIT":
                    break
            except:
                break
        conn.close()

    def run_server(self):
        self.server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server_socket.bind((HOST, PORT))
        self.server_socket.listen(5)
        self.log_msg(f"Сервер запущен на {HOST}:{PORT}")
        while self.server_running:
            try:
                conn, addr = self.server_socket.accept()
                threading.Thread(target=self.handle_client, args=(conn, addr), daemon=True).start()
            except:
                break

    def start_server(self):
        if not self.server_running:
            self.server_running = True
            threading.Thread(target=self.run_server, daemon=True).start()
            self.btn_start.config(state=tk.DISABLED)
            self.btn_stop.config(state=tk.NORMAL)
            self.log_msg("▶ Сервер запущен!")

    def stop_server(self):
        self.server_running = False
        if self.server_socket:
            self.server_socket.close()
        self.btn_start.config(state=tk.NORMAL)
        self.btn_stop.config(state=tk.DISABLED)
        self.log_msg("⏹ Сервер остановлен!")

    def upload_file(self):
        path = filedialog.askopenfilename(filetypes=[("JSON/XML", "*.json *.xml")])
        if not path:
            return
        name, ext = os.path.splitext(os.path.basename(path))
        if ext not in ['.json', '.xml']:
            messagebox.showerror("Ошибка", "Только .json и .xml!")
            return
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.connect((HOST, PORT))
            with open(path, 'rb') as f:
                data = f.read()
            sock.send(b"UPLOAD")
            sock.send(name.encode())
            sock.send(ext.encode())
            sock.send(str(len(data)).encode())
            sock.send(data)
            self.log_msg(f"✓ {os.path.basename(path)} загружен" if sock.recv(
                1024).decode() == "OK" else f"✗ {os.path.basename(path)} не прошел валидацию")
            sock.close()
        except:
            messagebox.showerror("Ошибка", "Сервер не запущен!")

    def download_file(self):
        name = self.filename_entry.get().strip()
        if not name:
            return
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.connect((HOST, PORT))
            sock.send(b"DOWNLOAD")
            sock.send(name.encode())
            size = sock.recv(1024).decode()
            if size == "-1":
                self.log_msg(f"✗ {name} не найден")
            else:
                sock.send(b"READY")
                data = b''
                while len(data) < int(size):
                    data += sock.recv(4096)
                path = filedialog.asksaveasfilename(defaultextension=".bin", initialfile=f"downloaded_{name}")
                if path:
                    with open(path, 'wb') as f:
                        f.write(data)
                    self.log_msg(f"✓ {name} скачан")
            sock.close()
        except:
            messagebox.showerror("Ошибка", "Сервер не запущен!")

    def list_files(self):
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.connect((HOST, PORT))
            sock.send(b"LIST")
            size = int(sock.recv(1024).decode())
            sock.send(b"READY")
            files = sock.recv(size).decode()
            self.log_msg("\n=== Файлы на сервере ===")
            for f in files.split('\n'):
                if f:
                    self.log_msg(f"  {f}")
            sock.close()
        except:
            messagebox.showerror("Ошибка", "Сервер не запущен!")


if __name__ == "__main__":
    root = tk.Tk()
    app = FileServerApp(root)
    root.mainloop()
