import tkinter as tk
from tkinter import ttk, messagebox
import requests
import threading

urls = [
    "https://github.com/",
    "https://www.binance.com/en",
    "https://tomtit.tomsk.ru/",
    "https://jsonplaceholder.typicode.com/",
    "https://moodle.tomtit-tomsk.ru/"
]


def check_url(url):
    try:
        r = requests.get(url, timeout=5)
        if r.status_code == 200:
            return "доступен", r.status_code
        elif r.status_code == 404:
            return "не найден", r.status_code
        elif r.status_code == 403 or r.status_code == 401:
            return "вход запрещен", r.status_code
        else:
            return "не доступен", r.status_code
    except:
        return "не доступен", "ошибка"


def check_all():
    btn.config(state=tk.DISABLED)
    for item in tree.get_children():
        tree.delete(item)

    def check_thread():
        for url in urls:
            status, code = check_url(url)
            tree.insert("", tk.END, values=(url, status, code))
        btn.config(state=tk.NORMAL)
        messagebox.showinfo("Готово", "Проверка завершена!")

    threading.Thread(target=check_thread).start()


root = tk.Tk()
root.title("Проверка сайтов")
root.geometry("600x400")

tk.Label(root, text="ПРОВЕРКА ДОСТУПНОСТИ САЙТОВ", font=("Arial", 14, "bold")).pack(pady=10)

columns = ("URL", "Статус", "Код")
tree = ttk.Treeview(root, columns=columns, show="headings", height=8)
tree.heading("URL", text="URL")
tree.heading("Статус", text="Статус")
tree.heading("Код", text="Код")
tree.column("URL", width=350)
tree.column("Статус", width=120)
tree.column("Код", width=80)
tree.pack(pady=10, padx=10, fill='both', expand=True)

btn = tk.Button(root, text="ПРОВЕРИТЬ ВСЕ САЙТЫ", command=check_all,
                bg='#2ecc71', fg='white', font=("Arial", 11), height=1)
btn.pack(pady=10)

root.mainloop()
